<%- include('errors', { errors }) %>

<form action="<%= formAction %>" method="POST" class="card shadow-sm needs-validation" novalidate>
  <div class="card-body">
    <div class="mb-3">
      <label for="name" class="form-label">Course Name <span class="text-danger">*</span></label>
      <input
        type="text"
        class="form-control"
        id="name"
        name="name"
        value="<%= course.name %>"
        maxlength="255"
        required
      >
      <div class="invalid-feedback">Course name is required.</div>
    </div>

    <div class="mb-3">
      <label for="duration" class="form-label">Course Duration <span class="text-danger">*</span></label>
      <input
        type="text"
        class="form-control"
        id="duration"
        name="duration"
        value="<%= course.duration %>"
        placeholder="e.g. 8 weeks"
        maxlength="100"
        required
      >
      <div class="invalid-feedback">Course duration is required.</div>
    </div>

    <div class="mb-3">
      <label for="fees" class="form-label">Course Fees ($) <span class="text-danger">*</span></label>
      <input
        type="number"
        class="form-control"
        id="fees"
        name="fees"
        value="<%= course.fees %>"
        min="0"
        step="0.01"
        required
      >
      <div class="invalid-feedback">Enter a valid fee (0 or greater).</div>
    </div>

    <div class="d-flex gap-2">
      <button type="submit" class="btn btn-primary"><%= submitLabel %></button>
      <a href="/courses" class="btn btn-outline-secondary">Cancel</a>
    </div>
  </div>
</form>
